{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "(gdb) Launch CplusAlg",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/CplusAlg",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "cmake build"
    },
    {
      "name": "(lldb) Launch CplusAlg",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/CplusAlg",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "MIMode": "lldb",
      "preLaunchTask": "cmake build"
    },
    {
      "name": "(gdb) Run unit_tests",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/tests/unit_tests",
      "args": [],
      "cwd": "${workspaceFolder}",
      "MIMode": "gdb",
      "preLaunchTask": "cmake build"
    },
    {
      "name": "(lldb) Run unit_tests",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/tests/unit_tests",
      "args": [],
      "cwd": "${workspaceFolder}",
      "MIMode": "lldb",
      "preLaunchTask": "cmake build"
    }
  ]
}
